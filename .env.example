# Vorlage — echte Werte in ".env" eintragen (gitignored).
# cp .env.example .env

# --- App-Runtime (Browser / Vite) ---------------------------------
# Diese Werte werden beim Build in die App eingebaut. Der Publishable-/
# anon-Key ist bewusst oeffentlich (durch Row Level Security geschuetzt).
# Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=DEIN-PUBLISHABLE-ODER-ANON-KEY

# Passcode, mit dem der Admin-Bereich entsperrt wird (frei waehlbar).
VITE_ADMIN_PASSCODE=beerpong

# --- Supabase CLI (Migrationen: `supabase db push`) ---------------
# Nur noetig, wenn du das DB-Schema per CLI ausrollst (statt SQL-Editor).
# Token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Projekt-Ref = die Subdomain der Projekt-URL (…//<ref>.supabase.co)
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# --- Cloudflare (wrangler CLI, optionaler manueller Deploy) -------
# Nur noetig fuer `npx wrangler deploy` von der Kommandozeile.
# Token: Dashboard -> My Profile -> API Tokens -> "Edit Cloudflare Workers"
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
